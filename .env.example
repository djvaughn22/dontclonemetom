# Real local adoptable-dog faces (within 30 miles) via the official Petfinder API.
# Free: create a key at https://www.petfinder.com/developers/ ("Get an API Key").
# Copy the API Key (Client ID) + Secret here AND set the same two vars in Vercel
# (Project → Settings → Environment Variables). Never commit real keys.
# The moment these are present, the page shows real dog faces near the ZIP;
# without them it falls back to 30-mile Petfinder/Adopt-a-Pet search links.
PETFINDER_KEY=your_petfinder_api_key_client_id
PETFINDER_SECRET=your_petfinder_secret
